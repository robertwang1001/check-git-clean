{
  "name": "check-git-clean",
  "type": "module",
  "version": "2.0.1",
  "packageManager": "pnpm@11.2.2",
  "description": "Check the cleanliness of a Git working directory, identifying untracked, unstaged, and uncommitted changes",
  "author": {
    "name": "Robert Wang",
    "email": "glorywong1001@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/robertwang1001/check-git-clean#readme",
  "repository": "github:robertwang1001/check-git-clean",
  "bugs": "https://github.com/robertwang1001/check-git-clean/issues",
  "keywords": [
    "git",
    "clean",
    "status",
    "untracked",
    "unstaged",
    "uncommitted",
    "changes",
    "repository",
    "workflow",
    "automation",
    "version control",
    "nodejs",
    "typescript"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "git-ignore-patterns",
    "index.d.ts",
    "index.js"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm simple-git-hooks",
    "prepublishOnly": "pnpm test && pnpm build",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage.enabled"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^24.12.4",
    "@vitest/coverage-istanbul": "^4.1.7",
    "copyfiles": "^2.4.1",
    "eslint": "^10.4.0",
    "lint-staged": "^17.0.5",
    "simple-git-hooks": "^2.13.1",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit ${1}",
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
